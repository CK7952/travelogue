# Application
environment=production
debug=false

# Database
database_url=postgresql+psycopg2://travelogue:change-me@127.0.0.1:5432/travelogue

# Storage
# Recommended on Tencent Cloud: use COS instead of local storage.
storage_type=cos
local_storage_path=./uploads

# COS (required when storage_type=cos)
cos_secret_id=AKIDxxxxxxxxxxxxxxxx
cos_secret_key=xxxxxxxxxxxxxxxx
cos_bucket=travelogue-1250000000
cos_region=ap-guangzhou

# Supabase (only needed when storage_type=supabase)
supabase_url=
supabase_service_role_key=
supabase_storage_bucket=travelogue

# Whisper
whisper_model=base
whisper_device=cpu
whisper_compute_type=int8

# LLM
llm_base_url=https://api.kimi.com/coding/v1
llm_api_key=sk-your-key
llm_model_clean=kimi-for-coding
llm_model_essay=kimi-for-coding

# Multimodal
multimodal_base_url=http://localhost:8000/v1
multimodal_model=Qwen2-VL-7B-Instruct

# CORS
# Do not use "*" in production.
cors_origins=https://your-web-domain.com,https://servicewechat.com
