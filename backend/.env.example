# Database
database_url=postgresql+psycopg2://travelogue:travelogue@localhost:5432/travelogue

# Storage
storage_type=local
local_storage_path=./uploads

# Whisper (tiny/base/small/medium/large-v3)
whisper_model=base
whisper_device=cpu
whisper_compute_type=int8

# LLM (OpenAI-compatible, e.g. vLLM / Ollama / DeepSeek API)
llm_base_url=http://localhost:8000/v1
llm_api_key=dummy
llm_model_clean=Qwen2.5-3B-Instruct
llm_model_essay=Qwen2.5-14B-Instruct

# Multimodal
multimodal_base_url=http://localhost:8000/v1
multimodal_model=Qwen2-VL-7B-Instruct
