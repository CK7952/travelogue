# Application
environment=development
debug=true

# Database
database_url=postgresql+psycopg2://travelogue:travelogue@localhost:5432/travelogue

# Storage (local | cos | supabase)
storage_type=local
local_storage_path=./uploads

# COS (Tencent Cloud Object Storage) - only needed when storage_type=cos
cos_secret_id=
cos_secret_key=
cos_bucket=
cos_region=ap-guangzhou

# Supabase - only needed when storage_type=supabase
supabase_url=
supabase_service_role_key=
supabase_storage_bucket=travelogue

# Whisper (tiny/base/small/medium/large-v3)
whisper_model=tiny
whisper_device=cpu
whisper_compute_type=int8

# LLM (OpenAI-compatible, e.g. DeepSeek / vLLM / Ollama)
# Used for text cleaning and tag suggestion. Pure text model is fine.
llm_base_url=https://api.deepseek.com/v1
llm_api_key=sk-your-key
llm_model_clean=deepseek-chat
llm_model_essay=deepseek-chat

# Vision LLM (OpenAI-compatible multimodal, e.g. Alibaba Qwen-VL / SiliconFlow / Zhipu GLM-4V)
# If configured, essay generation will use this model to understand BOTH text and photos.
# Leave empty to fall back to the text-only LLM above.
vision_base_url=
vision_api_key=
vision_model=

# Multimodal (legacy local endpoint, not required when vision_base_url is set)
multimodal_base_url=http://localhost:8000/v1
multimodal_model=Qwen2-VL-7B-Instruct

# CORS
# Development allows "*"; production must explicitly list allowed origins.
cors_origins=*
